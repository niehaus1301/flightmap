{
  "name": "flightmap",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "export-flights": "tsx scripts/exportMyFlightRadar.ts",
    "sync-history": "tsx scripts/syncHistory.ts",
    "enrich": "tsx scripts/enrichFromAeroAPI.ts",
    "generate-geojson": "tsx scripts/generateGeoJSON.ts",
    "update": "npm run export-flights && npm run sync-history && npm run enrich && npm run generate-geojson"
  },
  "dependencies": {
    "mapbox-gl": "^3.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
